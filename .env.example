# Copy this file to .env and fill in real values. .env is gitignored --
# never commit real credentials.

# Get a free API key at https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# How often the background service re-fetches from EIA. Optional --
# defaults to 6 if not set.
EIA_INGESTION_INTERVAL_HOURS=6

# Local Postgres credentials (fine to leave as defaults for local dev --
# this is a throwaway local database, not a real production credential)
POSTGRES_USER=outages
POSTGRES_PASSWORD=outages
POSTGRES_DB=outages_db

ASPNETCORE_ENVIRONMENT=Development
